# A browser-restricted Maps JavaScript API key. This key is necessarily public;
# restrict it by HTTP referrer and enable only Maps JavaScript + Places.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Base URL of the quoter-api backend. For local development run quoter-api
# on port 3001 (its default) and keep this value.
NEXT_PUBLIC_QUOTER_API_URL=http://localhost:3001

# Keep false/unset normally. The /dev workbench otherwise returns 404 in
# production.
ENABLE_DEV_LAB=
